<Window x:Class="WinSafeClean.Ui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="WinSafeClean"
        Width="1180"
        Height="740"
        MinWidth="940"
        MinHeight="580"
        Background="#F6F7F9">
    <Window.Resources>
        <Style x:Key="RiskLevelTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#5B6470" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding RiskLevel}" Value="Blocked">
                    <Setter Property="Foreground" Value="#A51D2D" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                </DataTrigger>
                <DataTrigger Binding="{Binding RiskLevel}" Value="HighRisk">
                    <Setter Property="Foreground" Value="#9A3412" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                </DataTrigger>
                <DataTrigger Binding="{Binding RiskLevel}" Value="MediumRisk">
                    <Setter Property="Foreground" Value="#7C5E10" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                </DataTrigger>
                <DataTrigger Binding="{Binding RiskLevel}" Value="LowRisk">
                    <Setter Property="Foreground" Value="#0F766E" />
                </DataTrigger>
                <DataTrigger Binding="{Binding RiskLevel}" Value="SafeCandidate">
                    <Setter Property="Foreground" Value="#047857" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                </DataTrigger>
                <DataTrigger Binding="{Binding RiskLevel}" Value="Unknown">
                    <Setter Property="Foreground" Value="#5B6470" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PreflightStatusTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#5B6470" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="Passed">
                    <Setter Property="Foreground" Value="#047857" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Warning">
                    <Setter Property="Foreground" Value="#9A3412" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Failed">
                    <Setter Property="Foreground" Value="#A51D2D" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="EmptyStateTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#5B6470" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="InputComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="ColumnHeaderTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#5B6470" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="20,16,20,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0"
                       Text="WinSafeClean"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Foreground="#20242A"
                       VerticalAlignment="Center" />
            <WrapPanel Grid.Row="1" Margin="0,12,0,0" HorizontalAlignment="Left">
                <ComboBox x:Name="RecentDocumentsBox"
                          Width="240"
                          Height="34"
                          Margin="0,0,8,0"
                          DisplayMemberPath="DisplayText"
                          SelectionChanged="RecentDocumentsBox_SelectionChanged" />
                <Button x:Name="OpenRecentButton"
                        Content="Open Recent"
                        Width="104"
                        Height="34"
                        Margin="0,0,8,0"
                        Padding="12,0"
                        Click="OpenRecent_Click" />
                <Button x:Name="ClearRecentButton"
                        Content="Clear"
                        Width="62"
                        Height="34"
                        Margin="0,0,8,0"
                        Padding="12,0"
                        Click="ClearRecent_Click" />
                <Button Content="Open Scan"
                        Width="96"
                        Height="34"
                        Margin="0,0,8,0"
                        Padding="14,0"
                        Click="OpenScanReport_Click" />
                <Button Content="Open Safety Check"
                        Width="138"
                        Height="34"
                        Margin="0,0,8,0"
                        Padding="14,0"
                        Click="OpenPreflight_Click" />
                <Button Content="Open Plan"
                        Width="96"
                        Height="34"
                        Padding="14,0"
                        Click="OpenPlan_Click" />
            </WrapPanel>
        </Grid>

        <TabControl Grid.Row="1" Margin="20,0,20,20">
            <TabItem x:Name="ScanTab" Header="Scan Report">
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="320" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="White" BorderBrush="#D6DAE0" BorderThickness="1">
                        <StackPanel Margin="14">
                            <TextBlock Text="Summary" FontSize="14" FontWeight="SemiBold" Foreground="#20242A" />
                            <TextBlock Text="{Binding TotalItems, StringFormat=Items: {0}}" Margin="0,10,0,6" Foreground="#4A515B" />
                            <TextBlock Text="{Binding TotalSizeDisplay, StringFormat=Size: {0}}" Margin="0,0,0,6" Foreground="#4A515B" />
                            <TextBlock Text="{Binding SchemaVersion, StringFormat=Schema: {0}}" Margin="0,0,0,18" Foreground="#4A515B" />

                            <TextBlock Text="Risks" FontWeight="SemiBold" Foreground="#20242A" />
                            <ItemsControl ItemsSource="{Binding RiskSummaries}" Margin="0,8,0,18">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <DockPanel Margin="0,0,0,6">
                                            <TextBlock Text="{Binding Label}" Foreground="#4A515B" />
                                            <TextBlock DockPanel.Dock="Right" Text="{Binding Count}" FontWeight="SemiBold" Foreground="#20242A" />
                                        </DockPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="Kinds" FontWeight="SemiBold" Foreground="#20242A" />
                            <ItemsControl ItemsSource="{Binding ItemKindSummaries}" Margin="0,8,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <DockPanel Margin="0,0,0,6">
                                            <TextBlock Text="{Binding Label}" Foreground="#4A515B" />
                                            <TextBlock DockPanel.Dock="Right" Text="{Binding Count}" FontWeight="SemiBold" Foreground="#20242A" />
                                        </DockPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="Largest" FontWeight="SemiBold" Foreground="#20242A" Margin="0,18,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasLargestItems}" Value="False">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <ItemsControl ItemsSource="{Binding LargestItems}" Margin="0,8,0,0">
                                <ItemsControl.Style>
                                    <Style TargetType="ItemsControl">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasLargestItems}" Value="False">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ItemsControl.Style>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="76" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Path}" TextTrimming="CharacterEllipsis" Foreground="#4A515B" />
                                            <TextBlock Grid.Column="1" Text="{Binding SizeDisplay}" TextAlignment="Right" FontWeight="SemiBold" Foreground="#20242A" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="Top Directories" FontWeight="SemiBold" Foreground="#20242A" Margin="0,18,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasLargestDirectories}" Value="False">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <ItemsControl ItemsSource="{Binding LargestDirectories}" Margin="0,8,0,0">
                                <ItemsControl.Style>
                                    <Style TargetType="ItemsControl">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasLargestDirectories}" Value="False">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ItemsControl.Style>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="76" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Path}" TextTrimming="CharacterEllipsis" Foreground="#4A515B" />
                                            <TextBlock Grid.Column="1" Text="{Binding SizeDisplay}" TextAlignment="Right" FontWeight="SemiBold" Foreground="#20242A" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Background="White" BorderBrush="#D6DAE0" BorderThickness="1">
                        <DockPanel>
                            <DockPanel DockPanel.Dock="Top" Margin="14,10,14,8" LastChildFill="False">
                                <TextBlock DockPanel.Dock="Left"
                                           Text="Scan Items"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="#20242A"
                                           VerticalAlignment="Center" />
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                    <Button Content="Copy Visible"
                                            Width="100"
                                            Height="28"
                                            Margin="0,0,8,0"
                                            Padding="8,0"
                                            Click="CopyScanVisible_Click" />
                                    <Button Content="Export CSV"
                                            Width="92"
                                            Height="28"
                                            Padding="8,0"
                                            Click="ExportScanVisible_Click" />
                                </StackPanel>
                            </DockPanel>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0" Margin="12,0,12,8">
                                    <Grid.Style>
                                        <Style TargetType="Grid">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasItems}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="108" />
                                        <ColumnDefinition Width="104" />
                                        <ColumnDefinition Width="118" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                        <TextBlock Text="Search" Style="{StaticResource ColumnHeaderTextStyle}" />
                                        <TextBox x:Name="ScanListSearchBox" Height="30" Style="{StaticResource InputTextBoxStyle}" TextChanged="ScanListFilter_Changed" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                        <TextBlock Text="Risk" Style="{StaticResource ColumnHeaderTextStyle}" />
                                        <ComboBox x:Name="ScanRiskFilterBox" Height="30" Style="{StaticResource InputComboBoxStyle}" SelectedIndex="0" SelectionChanged="ScanListFilter_Changed">
                                            <ComboBoxItem Content="All" />
                                            <ComboBoxItem Content="SafeCandidate" />
                                            <ComboBoxItem Content="LowRisk" />
                                            <ComboBoxItem Content="MediumRisk" />
                                            <ComboBoxItem Content="HighRisk" />
                                            <ComboBoxItem Content="Blocked" />
                                            <ComboBoxItem Content="Unknown" />
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Margin="0,0,8,0">
                                        <TextBlock Text="Type" Style="{StaticResource ColumnHeaderTextStyle}" />
                                        <ComboBox x:Name="ScanKindFilterBox" Height="30" Style="{StaticResource InputComboBoxStyle}" SelectedIndex="0" SelectionChanged="ScanListFilter_Changed">
                                            <ComboBoxItem Content="All" />
                                            <ComboBoxItem Content="File" />
                                            <ComboBoxItem Content="Directory" />
                                            <ComboBoxItem Content="Unknown" />
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Grid.Column="3">
                                        <TextBlock Text="Sort" Style="{StaticResource ColumnHeaderTextStyle}" />
                                        <ComboBox x:Name="ScanSortBox" Height="30" Style="{StaticResource InputComboBoxStyle}" SelectedIndex="0" SelectionChanged="ScanListFilter_Changed">
                                            <ComboBoxItem Content="Size desc" />
                                            <ComboBoxItem Content="Path A-Z" />
                                            <ComboBoxItem Content="Risk A-Z" />
                                            <ComboBoxItem Content="Type A-Z" />
                                        </ComboBox>
                                    </StackPanel>
                                </Grid>
                                <Grid Grid.Row="1" Margin="12,0,12,4">
                                    <Grid.Style>
                                        <Style TargetType="Grid">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasItems}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="110" />
                                        <ColumnDefinition Width="130" />
                                        <ColumnDefinition Width="130" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Path" Style="{StaticResource ColumnHeaderTextStyle}" />
                                    <TextBlock Grid.Column="1" Text="Size" Style="{StaticResource ColumnHeaderTextStyle}" />
                                    <TextBlock Grid.Column="2" Text="Kind" Style="{StaticResource ColumnHeaderTextStyle}" />
                                    <TextBlock Grid.Column="3" Text="Risk" Style="{StaticResource ColumnHeaderTextStyle}" />
                                    <TextBlock Grid.Column="4" Text="Action" Style="{StaticResource ColumnHeaderTextStyle}" />
                                </Grid>
                            <ListBox x:Name="ScanItemsList"
                                     Grid.Row="2"
                                     ItemsSource="{Binding Items}"
                                     BorderThickness="0"
                                     HorizontalContentAlignment="Stretch"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.Style>
                                    <Style TargetType="ListBox">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasItems}" Value="False">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.Style>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="6" MinHeight="52">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="100" />
                                                <ColumnDefinition Width="110" />
                                                <ColumnDefinition Width="130" />
                                                <ColumnDefinition Width="130" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Path}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" Foreground="#20242A" Margin="0,0,8,0" />
                                            <TextBlock Grid.Column="1" Text="{Binding SizeDisplay}" VerticalAlignment="Center" Foreground="#4A515B" Margin="0,0,8,0" />
                                            <TextBlock Grid.Column="2" Text="{Binding ItemKind}" VerticalAlignment="Center" Foreground="#4A515B" Margin="0,0,8,0" />
                                            <TextBlock Grid.Column="3" Text="{Binding RiskLevel}" VerticalAlignment="Center" Style="{StaticResource RiskLevelTextStyle}" Margin="0,0,8,0" />
                                            <TextBlock Grid.Column="4" Text="{Binding SuggestedAction}" VerticalAlignment="Center" Foreground="#4A515B" />
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <TextBlock Grid.Row="2" Text="{Binding EmptyStateMessage}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource EmptyStateTextStyle}">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasItems}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Grid.Row="2" Text="No scan items match filters.">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource EmptyStateTextStyle}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding HasItems}" Value="True" />
                                                    <Condition Binding="{Binding ElementName=ScanItemsList, Path=HasItems}" Value="False" />
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Visible" />
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            </Grid>
                        </DockPanel>
                    </Border>

                    <Border Grid.Column="4" Background="White" BorderBrush="#D6DAE0" BorderThickness="1">
                        <Grid>
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="14" DataContext="{Binding ElementName=ScanItemsList, Path=SelectedItem}">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ElementName=ScanItemsList, Path=SelectedItem}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock Text="Details" FontSize="14" FontWeight="SemiBold" Foreground="#20242A" />
                                    <TextBlock Text="{Binding Path}" Margin="0,12,0,14" TextWrapping="Wrap" Foreground="#20242A" />
                                    <TextBlock Text="Size" FontWeight="SemiBold" Foreground="#20242A" />
                                    <TextBlock Text="{Binding SizeDisplay}" Margin="0,8,0,14" TextWrapping="Wrap" Foreground="#4A515B" />
                                    <TextBlock Text="Last Modified" FontWeight="SemiBold" Foreground="#20242A" />
                                    <TextBlock Text="{Binding LastWriteTimeDisplay}" Margin="0,8,0,18" TextWrapping="Wrap" Foreground="#4A515B" />
                                    <TextBlock Text="Space Use" FontWeight="SemiBold" Foreground="#20242A" />
                                    <TextBlock Text="{Binding SpaceUseHint}" Margin="0,8,0,18" TextWrapping="Wrap" Foreground="#4A515B" />
                                    <TextBlock Text="Disposition" FontWeight="SemiBold" Foreground="#20242A" />
                                    <TextBlock Text="{Binding DispositionTitle}" Margin="0,8,0,4" TextWrapping="Wrap" FontWeight="SemiBold" Foreground="#20242A" />
                                    <TextBlock Text="{Binding DispositionMessage}" Margin="0,0,0,6" TextWrapping="Wrap" Foreground="#4A515B" />
                                    <TextBlock Text="{Binding DispositionNextStep}" Margin="0,0,0,18" TextWrapping="Wrap" Foreground="#047857" />
                                    <TextBlock Text="Reasons" FontWeight="SemiBold" Foreground="#20242A" />
                                    <TextBlock Text="{Binding Reasons}" Margin="0,8,0,18" TextWrapping="Wrap" Foreground="#4A515B" />
                                    <TextBlock Text="Blockers" FontWeight="SemiBold" Foreground="#20242A" />
                                    <TextBlock Text="{Binding Blockers}" Margin="0,8,0,18" TextWrapping="Wrap" Foreground="#4A515B" />
                                    <TextBlock Text="Evidence" FontWeight="SemiBold" Foreground="#20242A" />
                                    <TextBlock Text="{Binding Evidence}" Margin="0,8,0,0" TextWrapping="Wrap" Foreground="#4A515B" />
                                </StackPanel>
                            </ScrollViewer>
                            <TextBlock Text="{Binding DataContext.SelectionEmptyStateMessage, ElementName=ScanTab}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource EmptyStateTextStyle}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ElementName=ScanItemsList, Path=SelectedItem}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem x:Name="PreflightTab" Header="Safety Checklist">
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="White" BorderBrush="#D6DAE0" BorderThickness="1">
                        <StackPanel Margin="14">
                            <TextBlock Text="Summary" FontSize="14" FontWeight="SemiBold" Foreground="#20242A" />
                            <TextBlock Text="{Binding TotalChecks, StringFormat=Checks: {0}}" Margin="0,10,0,6" Foreground="#4A515B" />
                            <TextBlock Text="{Binding SchemaVersion, StringFormat=Schema: {0}}" Margin="0,0,0,6" Foreground="#4A515B" />
                            <TextBlock Text="{Binding IsExecutable, StringFormat=Executable: {0}}" Margin="0,0,0,18" Foreground="#4A515B" />

                            <TextBlock Text="Statuses" FontWeight="SemiBold" Foreground="#20242A" />
                            <ItemsControl ItemsSource="{Binding StatusSummaries}" Margin="0,8,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <DockPanel Margin="0,0,0,6">
                                            <TextBlock Text="{Binding Label}" Foreground="#4A515B" />
                                            <TextBlock DockPanel.Dock="Right" Text="{Binding Count}" FontWeight="SemiBold" Foreground="#20242A" />
                                        </DockPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Background="White" BorderBrush="#D6DAE0" BorderThickness="1">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="Checks" Margin="14,12,14,8" FontSize="14" FontWeight="SemiBold" Foreground="#20242A" />
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0" Margin="12,0,12,4">
                                    <Grid.Style>
                                        <Style TargetType="Grid">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasChecks}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="220" />
                                        <ColumnDefinition Width="110" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Code" Style="{StaticResource ColumnHeaderTextStyle}" />
                                    <TextBlock Grid.Column="1" Text="Status" Style="{StaticResource ColumnHeaderTextStyle}" />
                                    <TextBlock Grid.Column="2" Text="Message" Style="{StaticResource ColumnHeaderTextStyle}" />
                                </Grid>
                            <ListBox Grid.Row="1" ItemsSource="{Binding Checks}" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                <ListBox.Style>
                                    <Style TargetType="ListBox">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasChecks}" Value="False">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.Style>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="6" MinHeight="58">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="220" />
                                                <ColumnDefinition Width="110" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Code}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" Foreground="#20242A" />
                                            <TextBlock Grid.Column="1" Text="{Binding Status}" VerticalAlignment="Center" Style="{StaticResource PreflightStatusTextStyle}" />
                                            <TextBlock Grid.Column="2" Text="{Binding Message}" TextWrapping="Wrap" VerticalAlignment="Center" Foreground="#4A515B" />
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <TextBlock Grid.Row="1" Text="{Binding EmptyStateMessage}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource EmptyStateTextStyle}">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasChecks}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            </Grid>
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem x:Name="PlanTab" Header="Cleanup Plan">
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="320" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="White" BorderBrush="#D6DAE0" BorderThickness="1">
                        <StackPanel Margin="14">
                            <TextBlock Text="Summary" FontSize="14" FontWeight="SemiBold" Foreground="#20242A" />
                            <TextBlock Text="{Binding TotalItems, StringFormat=Items: {0}}" Margin="0,10,0,18" Foreground="#4A515B" />

                            <TextBlock Text="Actions" FontWeight="SemiBold" Foreground="#20242A" />
                            <ItemsControl ItemsSource="{Binding ActionSummaries}" Margin="0,8,0,18">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <DockPanel Margin="0,0,0,6">
                                            <TextBlock Text="{Binding Label}" Foreground="#4A515B" />
                                            <TextBlock DockPanel.Dock="Right" Text="{Binding Count}" FontWeight="SemiBold" Foreground="#20242A" />
                                        </DockPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="Risks" FontWeight="SemiBold" Foreground="#20242A" />
                            <ItemsControl ItemsSource="{Binding RiskSummaries}" Margin="0,8,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <DockPanel Margin="0,0,0,6">
                                            <TextBlock Text="{Binding Label}" Foreground="#4A515B" />
                                            <TextBlock DockPanel.Dock="Right" Text="{Binding Count}" FontWeight="SemiBold" Foreground="#20242A" />
                                        </DockPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Background="White" BorderBrush="#D6DAE0" BorderThickness="1">
                        <DockPanel>
                            <DockPanel DockPanel.Dock="Top" Margin="14,10,14,8" LastChildFill="False">
                                <TextBlock DockPanel.Dock="Left"
                                           Text="Plan Items"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="#20242A"
                                           VerticalAlignment="Center" />
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                    <Button Content="Copy Visible"
                                            Width="100"
                                            Height="28"
                                            Margin="0,0,8,0"
                                            Padding="8,0"
                                            Click="CopyPlanVisible_Click" />
                                    <Button Content="Export CSV"
                                            Width="92"
                                            Height="28"
                                            Padding="8,0"
                                            Click="ExportPlanVisible_Click" />
                                </StackPanel>
                            </DockPanel>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0" Margin="12,0,12,4">
                                    <Grid.Style>
                                        <Style TargetType="Grid">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasItems}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="128" />
                                        <ColumnDefinition Width="148" />
                                        <ColumnDefinition Width="118" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                        <TextBlock Text="Search" Style="{StaticResource ColumnHeaderTextStyle}" />
                                        <TextBox x:Name="PlanListSearchBox" Height="30" Style="{StaticResource InputTextBoxStyle}" TextChanged="PlanListFilter_Changed" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                        <TextBlock Text="Risk" Style="{StaticResource ColumnHeaderTextStyle}" />
                                        <ComboBox x:Name="PlanRiskFilterBox" Height="30" Style="{StaticResource InputComboBoxStyle}" SelectedIndex="0" SelectionChanged="PlanListFilter_Changed">
                                            <ComboBoxItem Content="All" />
                                            <ComboBoxItem Content="SafeCandidate" />
                                            <ComboBoxItem Content="LowRisk" />
                                            <ComboBoxItem Content="MediumRisk" />
                                            <ComboBoxItem Content="HighRisk" />
                                            <ComboBoxItem Content="Blocked" />
                                            <ComboBoxItem Content="Unknown" />
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Margin="0,0,8,0">
                                        <TextBlock Text="Action" Style="{StaticResource ColumnHeaderTextStyle}" />
                                        <ComboBox x:Name="PlanActionFilterBox" Height="30" Style="{StaticResource InputComboBoxStyle}" SelectedIndex="0" SelectionChanged="PlanListFilter_Changed">
                                            <ComboBoxItem Content="All" />
                                            <ComboBoxItem Content="Keep" />
                                            <ComboBoxItem Content="ReportOnly" />
                                            <ComboBoxItem Content="ReviewForQuarantine" />
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Grid.Column="3">
                                        <TextBlock Text="Sort" Style="{StaticResource ColumnHeaderTextStyle}" />
                                        <ComboBox x:Name="PlanSortBox" Height="30" Style="{StaticResource InputComboBoxStyle}" SelectedIndex="0" SelectionChanged="PlanListFilter_Changed">
                                            <ComboBoxItem Content="Path A-Z" />
                                            <ComboBoxItem Content="Action A-Z" />
                                            <ComboBoxItem Content="Risk A-Z" />
                                        </ComboBox>
                                    </StackPanel>
                                </Grid>
                                <Grid Grid.Row="1" Margin="12,0,12,4">
                                    <Grid.Style>
                                        <Style TargetType="Grid">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasItems}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="140" />
                                        <ColumnDefinition Width="130" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Path" Style="{StaticResource ColumnHeaderTextStyle}" />
                                    <TextBlock Grid.Column="1" Text="Action" Style="{StaticResource ColumnHeaderTextStyle}" />
                                    <TextBlock Grid.Column="2" Text="Risk" Style="{StaticResource ColumnHeaderTextStyle}" />
                                </Grid>
                            <ListBox x:Name="PlanItemsList"
                                     Grid.Row="2"
                                     ItemsSource="{Binding Items}"
                                     BorderThickness="0"
                                     HorizontalContentAlignment="Stretch"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.Style>
                                    <Style TargetType="ListBox">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasItems}" Value="False">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.Style>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="6" MinHeight="52">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="140" />
                                                <ColumnDefinition Width="130" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Path}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" Foreground="#20242A" Margin="0,0,8,0" />
                                            <TextBlock Grid.Column="1" Text="{Binding Action}" VerticalAlignment="Center" Foreground="#4A515B" TextTrimming="CharacterEllipsis" Margin="0,0,8,0" />
                                            <TextBlock Grid.Column="2" Text="{Binding RiskLevel}" VerticalAlignment="Center" Style="{StaticResource RiskLevelTextStyle}" />
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <TextBlock Grid.Row="2" Text="{Binding EmptyStateMessage}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource EmptyStateTextStyle}">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasItems}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Grid.Row="2" Text="No plan items match filters.">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource EmptyStateTextStyle}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding HasItems}" Value="True" />
                                                    <Condition Binding="{Binding ElementName=PlanItemsList, Path=HasItems}" Value="False" />
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Visible" />
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            </Grid>
                        </DockPanel>
                    </Border>

                    <Border Grid.Column="4" Background="White" BorderBrush="#D6DAE0" BorderThickness="1">
                        <Grid>
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="14" DataContext="{Binding ElementName=PlanItemsList, Path=SelectedItem}">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ElementName=PlanItemsList, Path=SelectedItem}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock Text="Details" FontSize="14" FontWeight="SemiBold" Foreground="#20242A" />
                                    <TextBlock Text="{Binding Path}" Margin="0,12,0,14" TextWrapping="Wrap" Foreground="#20242A" />
                                    <TextBlock Text="Disposition" FontWeight="SemiBold" Foreground="#20242A" />
                                    <TextBlock Text="{Binding DispositionTitle}" Margin="0,8,0,4" TextWrapping="Wrap" FontWeight="SemiBold" Foreground="#20242A" />
                                    <TextBlock Text="{Binding DispositionMessage}" Margin="0,0,0,6" TextWrapping="Wrap" Foreground="#4A515B" />
                                    <TextBlock Text="{Binding DispositionNextStep}" Margin="0,0,0,18" TextWrapping="Wrap" Foreground="#047857" />
                                    <TextBlock Text="Reasons" FontWeight="SemiBold" Foreground="#20242A" />
                                    <TextBlock Text="{Binding Reasons}" Margin="0,8,0,18" TextWrapping="Wrap" Foreground="#4A515B" />
                                    <TextBlock Text="Quarantine Path" FontWeight="SemiBold" Foreground="#20242A" />
                                    <TextBlock Text="{Binding QuarantinePath}" Margin="0,8,0,18" TextWrapping="Wrap" Foreground="#4A515B" />
                                    <TextBlock Text="Restore Metadata" FontWeight="SemiBold" Foreground="#20242A" />
                                    <TextBlock Text="{Binding RestoreMetadataPath}" Margin="0,8,0,14" TextWrapping="Wrap" Foreground="#4A515B" />
                                    <Button Content="Prepare Safety Check" Height="32" IsEnabled="{Binding CanPreparePreflight}" Click="PreparePreflightFromPlanItem_Click" />
                                </StackPanel>
                            </ScrollViewer>
                            <TextBlock Text="{Binding DataContext.SelectionEmptyStateMessage, ElementName=PlanTab}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource EmptyStateTextStyle}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ElementName=PlanItemsList, Path=SelectedItem}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem x:Name="ReadOnlyOpsTab" Header="Guided Review">
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="360" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="White" BorderBrush="#D6DAE0" BorderThickness="1">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="14">
                            <Border Background="#F8FAFC" BorderBrush="#D6DAE0" BorderThickness="1" Padding="10" Margin="0,0,0,14">
                                <TextBlock Text="Scan creates evidence. Plan reviews cleanup candidates. Direct delete is unavailable in this safety build."
                                           TextWrapping="Wrap"
                                           Foreground="#4A515B" />
                            </Border>

                            <TextBlock Text="Start Review" FontSize="14" FontWeight="SemiBold" Foreground="#20242A" />
                            <ItemsControl x:Name="QuickScanTargetsList" Margin="0,8,0,14">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="2" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding DisplayName}"
                                                Tag="{Binding}"
                                                Height="34"
                                                Margin="0,0,6,6"
                                                HorizontalContentAlignment="Center"
                                                ToolTip="{Binding Description}"
                                                Click="QuickScanTarget_Click" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="Evidence Scan" FontSize="14" FontWeight="SemiBold" Foreground="#20242A" />
                            <TextBlock Text="Target path" Margin="0,8,0,4" Foreground="#4A515B" />
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="64" />
                                    <ColumnDefinition Width="52" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="ScanPathBox" Grid.Column="0" Style="{StaticResource InputTextBoxStyle}" ToolTip="Folder or file path for scan" TextChanged="WorkflowInput_TextChanged" />
                                <Button Grid.Column="1" Content="Folder" Height="30" Margin="6,0,0,0" Click="BrowseScanFolder_Click" />
                                <Button Grid.Column="2" Content="File" Height="30" Margin="6,0,0,0" Click="BrowseScanFile_Click" />
                            </Grid>
                            <TextBlock Text="Scan report file" Margin="0,0,0,4" Foreground="#4A515B" />
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="58" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="ScanOutputPathBox" Grid.Column="0" Style="{StaticResource InputTextBoxStyle}" ToolTip="Output report path" />
                                <Button Grid.Column="1" Content="Save" Height="30" Margin="6,0,0,0" Click="BrowseScanOutput_Click" />
                            </Grid>
                            <DockPanel Margin="0,0,0,8">
                                <TextBlock DockPanel.Dock="Left" Text="Format" Width="74" VerticalAlignment="Center" Foreground="#4A515B" />
                                <ComboBox x:Name="ScanFormatBox" Style="{StaticResource InputComboBoxStyle}" SelectedIndex="0">
                                    <ComboBoxItem Content="json" />
                                    <ComboBoxItem Content="markdown" />
                                </ComboBox>
                            </DockPanel>
                            <DockPanel Margin="0,0,0,8">
                                <TextBlock DockPanel.Dock="Left" Text="Privacy" Width="74" VerticalAlignment="Center" Foreground="#4A515B" />
                                <ComboBox x:Name="ScanPrivacyBox" Style="{StaticResource InputComboBoxStyle}" SelectedIndex="0" SelectionChanged="PrivacySelection_Changed">
                                    <ComboBoxItem Content="full" />
                                    <ComboBoxItem Content="redacted" />
                                </ComboBox>
                            </DockPanel>
                            <TextBlock x:Name="ScanPrivacyHintText" Margin="0,-2,0,8" TextWrapping="Wrap" Foreground="#A16207" />
                            <CheckBox x:Name="ScanRecursiveBox" Content="Recursive" Margin="0,0,0,8" />
                            <CheckBox x:Name="ScanDirectorySizesBox" Content="Directory sizes" Margin="0,0,0,8" />
                            <TextBlock Text="Item limit" Margin="0,0,0,4" Foreground="#4A515B" />
                            <TextBox x:Name="ScanMaxItemsBox" Style="{StaticResource InputTextBoxStyle}" ToolTip="Optional positive item limit" Margin="0,0,0,8" />
                            <TextBlock Text="CleanerML evidence" Margin="0,0,0,4" Foreground="#4A515B" />
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="64" />
                                    <ColumnDefinition Width="52" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="ScanCleanerMlPathBox" Grid.Column="0" Style="{StaticResource InputTextBoxStyle}" ToolTip="Optional CleanerML file or directory" />
                                <Button Grid.Column="1" Content="Folder" Height="30" Margin="6,0,0,0" Click="BrowseScanCleanerMlFolder_Click" />
                                <Button Grid.Column="2" Content="File" Height="30" Margin="6,0,0,0" Click="BrowseScanCleanerMlFile_Click" />
                            </Grid>
                            <UniformGrid Columns="3" Margin="0,0,0,0">
                                <Button Content="Preview" Height="32" Margin="0,0,4,0" Click="BuildScan_Click" />
                                <Button Content="Run Scan" Height="32" Margin="4,0,4,0" Click="RunScan_Click" />
                                <Button Content="Use Target" Height="32" Margin="4,0,0,0" Click="UseScanForPlan_Click" />
                            </UniformGrid>

                            <Separator Margin="0,18,0,18" />

                            <TextBlock Text="Cleanup Plan" FontSize="14" FontWeight="SemiBold" Foreground="#20242A" />
                            <TextBlock Text="Target path" Margin="0,8,0,4" Foreground="#4A515B" />
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="64" />
                                    <ColumnDefinition Width="52" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="PlanPathBox" Grid.Column="0" Style="{StaticResource InputTextBoxStyle}" ToolTip="Folder or file path for plan" TextChanged="WorkflowInput_TextChanged" />
                                <Button Grid.Column="1" Content="Folder" Height="30" Margin="6,0,0,0" Click="BrowsePlanFolder_Click" />
                                <Button Grid.Column="2" Content="File" Height="30" Margin="6,0,0,0" Click="BrowsePlanFile_Click" />
                            </Grid>
                            <TextBlock Text="Cleanup plan file" Margin="0,0,0,4" Foreground="#4A515B" />
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="58" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="PlanOutputPathBox" Grid.Column="0" Style="{StaticResource InputTextBoxStyle}" ToolTip="Output cleanup plan path" />
                                <Button Grid.Column="1" Content="Save" Height="30" Margin="6,0,0,0" Click="BrowsePlanOutput_Click" />
                            </Grid>
                            <DockPanel Margin="0,0,0,8">
                                <TextBlock DockPanel.Dock="Left" Text="Format" Width="74" VerticalAlignment="Center" Foreground="#4A515B" />
                                <ComboBox x:Name="PlanFormatBox" Style="{StaticResource InputComboBoxStyle}" SelectedIndex="0">
                                    <ComboBoxItem Content="json" />
                                    <ComboBoxItem Content="markdown" />
                                </ComboBox>
                            </DockPanel>
                            <DockPanel Margin="0,0,0,8">
                                <TextBlock DockPanel.Dock="Left" Text="Privacy" Width="74" VerticalAlignment="Center" Foreground="#4A515B" />
                                <ComboBox x:Name="PlanPrivacyBox" Style="{StaticResource InputComboBoxStyle}" SelectedIndex="0" SelectionChanged="PrivacySelection_Changed">
                                    <ComboBoxItem Content="full" />
                                    <ComboBoxItem Content="redacted" />
                                </ComboBox>
                            </DockPanel>
                            <TextBlock x:Name="PlanPrivacyHintText" Margin="0,-2,0,8" TextWrapping="Wrap" Foreground="#A16207" />
                            <CheckBox x:Name="PlanRecursiveBox" Content="Recursive" Margin="0,0,0,8" />
                            <CheckBox x:Name="PlanDirectorySizesBox" Content="Directory sizes" Margin="0,0,0,8" />
                            <TextBlock Text="Item limit" Margin="0,0,0,4" Foreground="#4A515B" />
                            <TextBox x:Name="PlanMaxItemsBox" Style="{StaticResource InputTextBoxStyle}" ToolTip="Optional positive item limit" Margin="0,0,0,8" />
                            <TextBlock Text="CleanerML evidence" Margin="0,0,0,4" Foreground="#4A515B" />
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="64" />
                                    <ColumnDefinition Width="52" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="PlanCleanerMlPathBox" Grid.Column="0" Style="{StaticResource InputTextBoxStyle}" ToolTip="Optional CleanerML file or directory" />
                                <Button Grid.Column="1" Content="Folder" Height="30" Margin="6,0,0,0" Click="BrowsePlanCleanerMlFolder_Click" />
                                <Button Grid.Column="2" Content="File" Height="30" Margin="6,0,0,0" Click="BrowsePlanCleanerMlFile_Click" />
                            </Grid>
                            <UniformGrid Columns="2" Margin="0,0,0,0">
                                <Button Content="Preview" Height="32" Margin="0,0,4,0" Click="BuildPlan_Click" />
                                <Button Content="Create Plan" Height="32" Margin="4,0,0,0" Click="RunPlan_Click" />
                            </UniformGrid>

                            <Separator Margin="0,18,0,18" />

                            <TextBlock Text="Safety Check" FontSize="14" FontWeight="SemiBold" Foreground="#20242A" />
                            <TextBlock Text="Cleanup plan JSON" Margin="0,8,0,4" Foreground="#4A515B" />
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="58" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="PreflightPlanPathBox" Grid.Column="0" Style="{StaticResource InputTextBoxStyle}" ToolTip="Cleanup plan JSON path" TextChanged="WorkflowInput_TextChanged" />
                                <Button Grid.Column="1" Content="Open" Height="30" Margin="6,0,0,0" Click="BrowsePreflightPlan_Click" />
                            </Grid>
                            <TextBlock Text="Restore metadata JSON" Margin="0,0,0,4" Foreground="#4A515B" />
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="58" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="PreflightMetadataPathBox" Grid.Column="0" Style="{StaticResource InputTextBoxStyle}" ToolTip="Restore metadata JSON path" TextChanged="WorkflowInput_TextChanged" />
                                <Button Grid.Column="1" Content="Open" Height="30" Margin="6,0,0,0" Click="BrowsePreflightMetadata_Click" />
                            </Grid>
                            <TextBlock Text="Safety checklist file" Margin="0,0,0,4" Foreground="#4A515B" />
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="58" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="PreflightOutputPathBox" Grid.Column="0" Style="{StaticResource InputTextBoxStyle}" ToolTip="Output preflight checklist path" />
                                <Button Grid.Column="1" Content="Save" Height="30" Margin="6,0,0,0" Click="BrowsePreflightOutput_Click" />
                            </Grid>
                            <DockPanel Margin="0,0,0,8">
                                <TextBlock DockPanel.Dock="Left" Text="Format" Width="74" VerticalAlignment="Center" Foreground="#4A515B" />
                                <ComboBox x:Name="PreflightFormatBox" Style="{StaticResource InputComboBoxStyle}" SelectedIndex="0">
                                    <ComboBoxItem Content="json" />
                                    <ComboBoxItem Content="markdown" />
                                </ComboBox>
                            </DockPanel>
                            <CheckBox x:Name="PreflightManualConfirmationBox" Content="Manual confirmation" Margin="0,0,0,8" />
                            <UniformGrid Columns="2" Margin="0,0,0,0">
                                <Button Content="Preview" Height="32" Margin="0,0,4,0" Click="BuildPreflight_Click" />
                                <Button Content="Run Check" Height="32" Margin="4,0,0,0" Click="RunPreflight_Click" />
                            </UniformGrid>

                            <Separator Margin="0,18,0,18" />

                            <TextBlock Text="Guarded CLI Handoff" FontSize="14" FontWeight="SemiBold" Foreground="#20242A" />
                            <TextBlock Text="Builds copyable quarantine or restore CLI commands only. The UI does not run file-moving commands."
                                       Margin="0,8,0,8"
                                       TextWrapping="Wrap"
                                       Foreground="#4A515B" />
                            <TextBlock Text="Operation log" Margin="0,0,0,4" Foreground="#4A515B" />
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="58" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="GuardedOperationLogPathBox" Grid.Column="0" Style="{StaticResource InputTextBoxStyle}" ToolTip="Optional JSONL operation log path" />
                                <Button Grid.Column="1" Content="Save" Height="30" Margin="6,0,0,0" Click="BrowseGuardedOperationLog_Click" />
                            </Grid>
                            <CheckBox x:Name="GuardedManualConfirmationBox" Content="I have reviewed the preflight checklist" Margin="0,0,0,8" />
                            <CheckBox x:Name="GuardedMoveAcknowledgementBox" Content="I understand the CLI command moves files" Margin="0,0,0,8" />
                            <CheckBox x:Name="GuardedAllowLegacyMetadataBox" Content="Allow legacy restore metadata without hash" Margin="0,0,0,8" />
                            <UniformGrid Columns="3" Margin="0,0,0,0">
                                <Button Content="Quarantine CLI" Height="32" Margin="0,0,4,0" Click="BuildQuarantineCli_Click" />
                                <Button Content="Restore CLI" Height="32" Margin="4,0,4,0" Click="BuildRestoreCli_Click" />
                                <Button Content="Copy Command" Height="32" Margin="4,0,0,0" Click="CopyCommand_Click" />
                            </UniformGrid>
                        </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <Border Grid.Column="2" Background="White" BorderBrush="#D6DAE0" BorderThickness="1">
                        <DockPanel>
                            <Border DockPanel.Dock="Top" Background="#F8FAFC" BorderBrush="#D6DAE0" BorderThickness="0,0,0,1" Padding="14">
                                <StackPanel>
                                    <TextBlock Text="Workflow"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="#20242A" />
                                    <TextBlock x:Name="WorkflowCurrentStepTitleText"
                                               Margin="0,8,0,4"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Foreground="#20242A" />
                                    <TextBlock x:Name="WorkflowCurrentStepDetailText"
                                               Margin="0,0,0,10"
                                               TextWrapping="Wrap"
                                               Foreground="#4A515B" />
                                    <UniformGrid Columns="3" Margin="0,12,0,10">
                                        <Border BorderBrush="#D6DAE0" BorderThickness="1" Padding="10" Margin="0,0,6,0" Background="White">
                                            <StackPanel>
                                                <TextBlock Text="Scan" FontWeight="SemiBold" Foreground="#20242A" />
                                                <TextBlock x:Name="WorkflowScanStatusText" Margin="0,6,0,0" Foreground="#4A515B" />
                                            </StackPanel>
                                        </Border>
                                        <Border BorderBrush="#D6DAE0" BorderThickness="1" Padding="10" Margin="3,0,3,0" Background="White">
                                            <StackPanel>
                                                <TextBlock Text="Plan" FontWeight="SemiBold" Foreground="#20242A" />
                                                <TextBlock x:Name="WorkflowPlanStatusText" Margin="0,6,0,0" Foreground="#4A515B" />
                                            </StackPanel>
                                        </Border>
                                        <Border BorderBrush="#D6DAE0" BorderThickness="1" Padding="10" Margin="6,0,0,0" Background="White">
                                            <StackPanel>
                                                <TextBlock Text="Safety Check" FontWeight="SemiBold" Foreground="#20242A" />
                                                <TextBlock x:Name="WorkflowPreflightStatusText" Margin="0,6,0,0" Foreground="#4A515B" />
                                            </StackPanel>
                                        </Border>
                                    </UniformGrid>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="132" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="WorkflowStatusText"
                                                   Grid.Column="0"
                                                   Margin="0,0,12,0"
                                                   VerticalAlignment="Center"
                                                   TextWrapping="Wrap"
                                                   Foreground="#4A515B" />
                                        <Button x:Name="WorkflowPrimaryActionButton"
                                                Grid.Column="1"
                                                Height="32"
                                                Click="WorkflowPrimaryAction_Click" />
                                    </Grid>
                                    <TextBlock x:Name="WorkflowSafetyBoundaryText"
                                               Margin="0,10,0,0"
                                               TextWrapping="Wrap"
                                               Foreground="#A16207" />
                                </StackPanel>
                            </Border>
                            <TextBlock DockPanel.Dock="Top"
                                       Text="Command"
                                       Margin="14,12,14,8"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="#20242A" />
                            <TextBlock x:Name="OperationStatusText"
                                       DockPanel.Dock="Top"
                                       Margin="14,0,14,8"
                                       TextWrapping="Wrap"
                                       Foreground="#5B6470" />
                            <TextBox x:Name="OperationCommandText"
                                     Margin="14"
                                     AcceptsReturn="True"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     BorderThickness="0"
                                     Foreground="#20242A"
                                     Background="#F6F7F9" />
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
